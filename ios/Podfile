platform :ios, '13.0'

# CocoaPods analytics sends network stats. If you're behind a firewall or have a slow network,
# timeout errors may occur. In that case, you can disable it by setting the following environment variable:
# ENV['COCOAPODS_DISABLE_STATS'] = '1'

project 'Runner', {
  'Debug' => :debug,
  'Release' => :release,
  'Profile' => :profile,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get has been executed."
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/\AFLUTTER_ROOT=(.*)\z/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('..', 'Flutter', 'flutter_export_ios.rb'), __FILE__)

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    
    # Permission Handler Configuration
    target.build_configurations.each do |config|
      # Ensure we don't interfere with standard Flutter settings
      
      # 1. Get existing definitions (handle nil, String, or Array)
      existing_defs = config.build_settings['GCC_PREPROCESSOR_DEFINITIONS']
      if existing_defs.nil?
        definitions = ['$(inherited)']
      elsif existing_defs.is_a?(String)
        definitions = existing_defs.split(' ')
      else
        definitions = existing_defs.dup
      end
      
      # 2. Add required permission macros if they don't exist
      ['PERMISSION_LOCATION=1', 'PERMISSION_NOTIFICATIONS=1', 'PERMISSION_SENSORS=1'].each do |perm|
        definitions << perm unless definitions.include?(perm)
      end
      
      # 3. Save back to build settings
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = definitions
    end
  end
end

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end
