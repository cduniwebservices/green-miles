platform :ios, '13.0'

# Flutter-specific generated utils
# This file is generated by 'flutter pub get' in the build environment
begin
  require_relative File.join('..', 'Flutter', 'generated_tool_utils.rb')
rescue LoadError
  # Fallback for older Flutter versions
  require File.expand_path(File.join('..', 'Flutter', 'flutter_export_ios.rb'), __FILE__)
end

project 'Runner', {
  'Debug' => :debug,
  'Release' => :release,
  'Profile' => :profile,
}

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    
    # Permission Handler Configuration
    target.build_configurations.each do |config|
      # Ensure definitions array exists and handle nil/String/Array types
      existing_defs = config.build_settings['GCC_PREPROCESSOR_DEFINITIONS']
      if existing_defs.nil?
        definitions = ['$(inherited)']
      elsif existing_defs.is_a?(String)
        definitions = existing_defs.split(' ')
      else
        definitions = existing_defs.dup
      end
      
      # Inject permission macros
      ['PERMISSION_LOCATION=1', 'PERMISSION_NOTIFICATIONS=1', 'PERMISSION_SENSORS=1'].each do |perm|
        definitions << perm unless definitions.include?(perm)
      end
      
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] = definitions
    end
  end
end

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end
